{
  "name": "example-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "npm run build && vite preview",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "refresh-auth": "cd .. && npm run build && mkdir -p example-vite/vendor && npm pack --pack-destination example-vite/vendor && cd example-vite && mv -f vendor/adrianhall-cloudflare-auth-*.tgz vendor/adrianhall-cloudflare-auth.tgz && npm install ./vendor/adrianhall-cloudflare-auth.tgz"
  },
  "dependencies": {
    "@adrianhall/cloudflare-auth": "github:adrianhall/cloudflare-auth#1.3.0",
    "hono": "^4.12.16",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.40.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wrangler": "^4.100.0"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "workerd@1.20260611.1": true,
    "workerd@1.20260625.1": true,
    "fsevents@2.3.3": true,
    "esbuild@0.25.12": true,
    "esbuild@0.27.3": true,
    "esbuild@0.28.1": true
  }
}
