{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src", "tests", "*.config.ts", "*.config.js"],
  // The e2e-demo fixture is a self-contained Vite/React/Worker app with its
  // own deps and tsconfig; it must not be type-checked by the root program.
  "exclude": ["tests/e2e-demo"]
}
