{
  "name": "@adrianhall/cloudflare-auth",
  "version": "0.1.0",
  "description": "Hono middleware for Cloudflare Access authentication with local development support",
  "license": "MIT",
  "author": "Adrian Hall",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianhall/cloudflare-auth.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist coverage",
    "check": "run-s check:prettier check:types check:eslint test",
    "check:eslint": "eslint src tests *.config.{js,ts}",
    "check:prettier": "prettier --check .",
    "check:types": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky || true"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "hono": "^4.12.16",
    "husky": "^9.1.7",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
