{
  "name": "@adrianhall/cloudflare-auth",
  "version": "1.1.1",
  "description": "Hono middleware for Cloudflare Access authentication with local development support",
  "license": "MIT",
  "author": "Adrian Hall",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianhall/cloudflare-auth.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist coverage",
    "check": "run-s check:prettier check:types check:eslint test:unit",
    "check:eslint": "eslint src tests *.config.{js,ts}",
    "check:full": "run-s check test:a11y test:e2e",
    "check:prettier": "prettier --check .",
    "check:types": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:a11y": "vitest run --project a11y",
    "test:coverage": "vitest run --coverage --project unit",
    "test:e2e": "playwright test",
    "pretest:e2e:demo": "npm --prefix example-vite run refresh-auth",
    "test:e2e:demo": "playwright test --config playwright.demo.config.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "peerDependencies": {
    "hono": "^4.0.0",
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@hono/node-server": "^2.0.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "axe-core": "^4.11.4",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "hono": "^4.12.16",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.5",
    "vitest-canvas-mock": "^1.1.4"
  }
}
